{
  "//": "Configuração OpenClaw para intenção de compra - apenas browser",
  "//": "Use: OPENCLAW_CONFIG_PATH=./config/openclaw.json openclaw gateway",
  "//": "O agente usa browser para extrair leads; o script mailobot salva no banco",

  "agents": {
    "defaults": {
      "workspace": ".",
      "sandbox": {
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "ro"
      }
    }
  },

  "tools": {
    "allow": [
      "read",
      "browser"
    ],
    "deny": [
      "write",
      "edit",
      "apply_patch",
      "exec",
      "bash",
      "process",
      "gateway",
      "web_search",
      "web_fetch",
      "sessions_list",
      "session_status",
      "group:nodes",
      "group:memory"
    ],
    "exec": {
      "security": "deny"
    },
    "elevated": {
      "enabled": false
    },
    "sandbox": {
      "tools": {
        "allow": [
          "read",
          "browser"
        ],
        "deny": [
          "write",
          "edit",
          "apply_patch",
          "group:runtime",
          "group:memory",
          "group:nodes"
        ]
      }
    }
  }
}
