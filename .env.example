# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mailobot

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3000
API_KEY=your-secret-api-key

# Scraper settings (optional)
PLAYWRIGHT_HEADLESS=true
SCRAPER_DELAY_MS=2000
SCRAPER_TIMEOUT_MS=30000

# Instagram login (required for DESCOBERTA_NO_INSTAGRAM - perfis exigem autenticação)
INSTAGRAM_USER=
INSTAGRAM_PASSWORD=
INSTAGRAM_STATE_PATH=./.instagram-state.json

# LinkedIn login (required for EMPRESAS_LINKEDIN - busca exige autenticação)
LINKEDIN_USER=
LINKEDIN_PASSWORD=
LINKEDIN_STATE_PATH=./.linkedin-state.json
